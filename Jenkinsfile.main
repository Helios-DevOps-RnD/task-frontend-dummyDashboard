// Jenkins Pipeline for Main Branch (Production)
// Stages: Query Staging Image → Approval → Update GitOps → Deploy to Production
// This is a PROMOTION pipeline that promotes the latest staging image to production

pipeline {
    agent any

    environment {
        // ---------- Docker & Harbor ----------
        DOCKER_REGISTRY = 'registry.hms.evanlwp.my.id'
        DOCKER_REPO     = 'hms/fe'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/${DOCKER_REPO}"

        // ---------- GitOps Configuration ----------
        GITOPS_REPO_URL = 'https://github.com/Helios-DevOps-RnD/gitops-hms.git'
        OVERLAY_DIR     = 'apps/hms-fe/overlays/production'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 2, unit: 'HOURS')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        // =====================================================================
        // 1. QUERY LATEST STAGING IMAGE
        // =====================================================================
        stage('Query Latest Staging Image') {
            steps {
                echo "� Querying latest image from staging deployment..."
                withCredentials([usernamePassword(
                    credentialsId:    'harbor-credentials',
                    usernameVariable: 'HARBOR_USERNAME',
                    passwordVariable: 'HARBOR_PASSWORD'
                )]) {
                    sh '''
                        set -eu

                        # Login to Harbor
                        echo ${HARBOR_PASSWORD} | docker login -u ${HARBOR_USERNAME} --password-stdin ${DOCKER_REGISTRY}

                        # Get the latest image tag from staging gitops repository
                        GITOPS_TEMP="${WORKSPACE}/gitops-query-temp"
                        rm -rf ${GITOPS_TEMP}
                        git clone ${GITOPS_REPO_URL} ${GITOPS_TEMP}

                        # Extract image tag from staging patch-image.yaml
                        STAGING_PATCH="${GITOPS_TEMP}/apps/hms-fe/overlays/staging/patch-image.yaml"
                        STAGING_IMAGE=$(grep -oP 'value: \K.*' ${STAGING_PATCH} | head -1)

                        echo "📦 Latest staging image: ${STAGING_IMAGE}"
                        echo "${STAGING_IMAGE}" > ${WORKSPACE}/staging-image.txt

                        # Verify image exists in Harbor
                        IMAGE_TAG=$(echo ${STAGING_IMAGE} | cut -d: -f2)
                        docker pull ${STAGING_IMAGE} || {
                            echo "❌ Failed to pull image ${STAGING_IMAGE}"
                            exit 1
                        }

                        echo "✅ Image verified in Harbor"

                        # Cleanup
                        rm -rf ${GITOPS_TEMP}
                        docker logout ${DOCKER_REGISTRY}
                    '''
                }
                script {
                    env.STAGING_IMAGE = readFile("${WORKSPACE}/staging-image.txt").trim()
                    echo "🎯 Will promote: ${STAGING_IMAGE}"
                }
            }
        }

        // =====================================================================
        // 2. APPROVAL STAGE
        // =====================================================================
        stage('Approval for Production Promotion') {
            steps {
                script {
                    def userInput = input(
                        id: 'ProductionApproval',
                        message: "Promote to Production?",
                        parameters: [
                            string(
                                name: 'IMAGE_TAG',
                                defaultValue: "${STAGING_IMAGE}",
                                description: 'Docker image to promote to production (can be modified)'
                            ),
                            booleanParam(
                                name: 'CONFIRM_PROMOTION',
                                defaultValue: false,
                                description: 'Check to confirm promotion to production'
                            )
                        ]
                    )

                    if (!userInput.CONFIRM_PROMOTION) {
                        error("❌ Production promotion cancelled by user")
                    }

                    env.APPROVED_IMAGE = userInput.IMAGE_TAG
                    echo "✅ Approved for production: ${APPROVED_IMAGE}"
                }
            }
        }

        // =====================================================================
        // 3. UPDATE GITOPS REPOSITORY
        //    Update patch-image.yaml in production overlay with approved image
        // =====================================================================
        stage('Update GitOps Repository') {
            steps {
                echo "� Updating GitOps repository with approved image..."
                withCredentials([usernamePassword(
                    credentialsId:    'git-credentials',
                    usernameVariable: 'GIT_USERNAME',
                    passwordVariable: 'GIT_PASSWORD'
                )]) {
                    sh '''
                        set -eu

                        # Configure Git identity for the bot commit
                        git config --global user.email "jenkins-bot@hms.evanlwp.my.id"
                        git config --global user.name  "HMS Jenkins Bot"

                        # Fresh clone — avoid stale local state across builds
                        GITOPS_DIR="${WORKSPACE}/gitops-hms-temp"
                        rm -rf ${GITOPS_DIR}

                        # Set up credential helper from temp file
                        CRED_FILE="${WORKSPACE}/.git-credentials"
                        echo "https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com" > ${CRED_FILE}
                        git config --global credential.helper "store --file=${CRED_FILE}"

                        git clone ${GITOPS_REPO_URL} ${GITOPS_DIR}
                        cd ${GITOPS_DIR}

                        # ---- Update patch-image.yaml in production ----
                        PATCH_FILE="${OVERLAY_DIR}/patch-image.yaml"
                        
                        # Replace the image value with approved image
                        sed -i "s|value: .*|value: ${APPROVED_IMAGE}|g" ${PATCH_FILE}
                        
                        echo "Updated patch-image.yaml:"
                        cat ${PATCH_FILE}

                        # ---- Commit + push ----
                        git add ${PATCH_FILE}

                        if git diff --cached --quiet; then
                            echo "[gitops] No changes to commit."
                        else
                            git commit -m "ci(hms-fe-production): promote ${APPROVED_IMAGE}

Promoted from staging to production
Build URL: ${BUILD_URL}
Approved by: Jenkins Promotion Pipeline"
                            git push origin main
                            echo "✅ Pushed production update to gitops-hms"
                        fi

                        # Cleanup
                        cd ${WORKSPACE}
                        rm -rf ${GITOPS_DIR}
                        rm -f ${CRED_FILE}
                        git config --global --unset credential.helper
                    '''
                }
            }
        }
    }

    // =========================================================================
    // POST ACTIONS
    // =========================================================================
    post {
        success {
            script {
                echo "════════════════════════════════════════"
                echo "✅ Production promotion completed successfully!"
                echo "════════════════════════════════════════"
                echo "🎯 Promoted Image: ${APPROVED_IMAGE}"
                echo "📍 Target: apps/hms-fe/overlays/production"
                echo "🔗 Build URL: ${BUILD_URL}"
                echo "════════════════════════════════════════"
            }
        }
        failure {
            script {
                echo "════════════════════════════════════════"
                echo "❌ Production promotion failed!"
                echo "════════════════════════════════════════"
                echo "🔗 Build URL: ${BUILD_URL}"
                echo "════════════════════════════════════════"
            }
        }
        always {
            // Cleanup temporary files
            sh 'rm -f ${WORKSPACE}/staging-image.txt || true'
        }
    }
}
