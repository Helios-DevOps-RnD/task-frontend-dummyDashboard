# Build artefacts & dev junk — must not land in the image context
node_modules
.next
out
build
dist

# VCS / CI
.git
.gitignore
.github

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Docs (not needed at runtime)
README.md
CONTRIBUTING.md
Dockerfile
.dockerignore

# Env / secrets — never bake these into the image
.env
.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
New folder
